function PrudenceBubble({ text, mood = "happy", size = 80 }) {
  return (
    <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 2 }}>
      <div style={{ background: "rgba(255,255,255,0.92)", borderRadius: 16, padding: "8px 14px", fontSize: 12, color: "#3D2C35", fontStyle: "italic", maxWidth: 220, textAlign: "center", boxShadow: "0 2px 10px rgba(200,140,160,0.1)", position: "relative", fontFamily: FNT }}>
        {text}
        <div style={{ position: "absolute", bottom: -6, left: "50%", marginLeft: -6, width: 12, height: 12, background: "rgba(255,255,255,0.92)", transform: "rotate(45deg)", borderRadius: 2 }} />
      </div>
      <Prudence mood={mood} size={size} />
    </div>
  );
}

function getDailyQuote() {
  const t = new Date();
  return QUOTES[Math.floor((t - new Date(t.getFullYear(), 0, 0)) / 86400000) % QUOTES.length];
}
function getCountdown(d) {
  if (!d) return null;
  const diff = new Date(d + "T23:59:59") - new Date();
  if (diff <= 0) return { d: 0, h: 0, m: 0, done: true };
  return { d: Math.floor(diff / 864e5), h: Math.floor(diff % 864e5 / 36e5), m: Math.floor(diff % 36e5 / 6e4), done: false };
}

// Storage helper — uses localStorage
const storage = {
  get: (key) => { try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : null; } catch { return null; } },
  set: (key, val) => { try { localStorage.setItem(key, JSON.stringify(val)); } catch {} },
};

