    }
    setLoaded(true);
  }, []);

  // Save to localStorage
  const save = useCallback((ov = {}) => {
    storage.set("myp-data", { p1, p2, rd, notes, gests, sdates, photos, qr, ...ov });
  }, [p1, p2, rd, notes, gests, sdates, photos, qr]);

  useEffect(() => { if (loaded && setup) save(); }, [p1, p2, rd, notes, gests, sdates, photos, qr, loaded, setup, save]);

  const dq = getDailyQuote(), cd = getCountdown(rd), tk = new Date().toISOString().slice(0, 10);

  const prudenceSays = () => {
    const h = new Date().getHours();
    if (h < 6) return { t: "Prudence is sleeping... you should be too 💤", m: "sleeping" };
    if (h < 10) return { t: "Good morning, lovebirds! ☀️", m: "happy" };
    if (h < 14) return { t: "Psst... send your pookie a note! 💌", m: "waving" };
    if (h < 18) return { t: "Missing your person? Prudence gets it.", m: "sad" };
    if (h < 21) return { t: "Evening cuddle vibes from Prudence 🌙", m: "love" };
    return { t: "Prudence is getting sleepy... 💕", m: "sleeping" };
  };

  const sendGift = () => {
    if (!giftModal) return;
    const entry = { ...giftModal, note: giftNote.trim(), time: new Date().toISOString(), id: Date.now() };
    setGests(prev => [entry, ...prev]);
    setGAnim(giftModal);
    setTimeout(() => setGAnim(null), 2200);
    setGiftModal(null);
    setGiftNote("");
  };

  if (!loaded) return (
    <div style={{ minHeight: "100dvh", display: "flex", alignItems: "center", justifyContent: "center", background: `linear-gradient(160deg,${S.blush},${S.lav},${S.cream})`, fontFamily: FNT }}><style>{CSS}</style>
      <div style={{ textAlign: "center", animation: "float 2s ease-in-out infinite" }}><Prudence mood="sleeping" size={130} /><div style={{ color: S.txL, fontSize: 13, letterSpacing: 2, marginTop: 8 }}>Loading...</div></div>
    </div>
  );

  if (!setup) return (
    <div style={{ minHeight: "100dvh", display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", background: `linear-gradient(160deg,${S.blush},${S.lav},${S.cream})`, fontFamily: FNT, padding: 24 }}><style>{CSS}</style>
      <div style={{ animation: "fadeUp 0.8s ease", textAlign: "center", maxWidth: 360, width: "100%" }}>
        <div style={{ animation: "float 3s ease-in-out infinite" }}><Prudence mood="love" size={130} /></div>
        <h1 style={{ fontFamily: FNTD, fontSize: 32, color: S.tx, marginBottom: 2, marginTop: 8, fontWeight: 700 }}>Miss You, Pookie</h1>
        <p style={{ color: S.txL, fontSize: 13, marginBottom: 4, fontStyle: "italic", fontFamily: FNTD }}>Stay close, even when you're far apart</p>
        <p style={{ color: S.txM, fontSize: 11, marginBottom: 28 }}>Prudence will keep you company 🐾</p>
        <div style={{ ...CRD, borderRadius: 24, padding: 28 }}>
          <p style={{ fontSize: 12, color: S.txM, marginBottom: 16, letterSpacing: 1, textTransform: "uppercase" }}>Set up your couple</p>
          <input value={p1} onChange={e => setP1(e.target.value)} placeholder="Partner 1 name" style={INP} />
          <input value={p2} onChange={e => setP2(e.target.value)} placeholder="Partner 2 name" style={INP} />
          <button onClick={() => { if (p1.trim() && p2.trim()) { setSetup(true); save({ p1: p1.trim(), p2: p2.trim() }); } }} style={{ ...BTN, width: "100%", marginTop: 8, opacity: (p1.trim() && p2.trim()) ? 1 : 0.5 }}>Begin Your Journey 💕</button>
        </div>
      </div>
    </div>
  );

  const tabs = [{ id: "home", e: "🏠", l: "Home" }, { id: "feed", e: "📸", l: "Our Feed" }, { id: "notes", e: "💌", l: "Notes" }, { id: "gestures", e: "🎁", l: "Gifts" }, { id: "dates", e: "✨", l: "Dates" }];
  const pru = prudenceSays();

  return (
    <div style={{ minHeight: "100dvh", background: `linear-gradient(170deg,${S.blush} 0%,${S.cream} 40%,${S.lav} 100%)`, fontFamily: FNT, paddingBottom: 80, position: "relative", overflow: "hidden" }}>
      <style>{CSS}</style>

      {gAnim && <div style={{ position: "fixed", inset: 0, zIndex: 999, display: "flex", alignItems: "center", justifyContent: "center", pointerEvents: "none" }}><div style={{ fontSize: 80, animation: "gestureFloat 2s ease-out forwards" }}>{gAnim.emoji}</div></div>}

      {giftModal && <div style={{ position: "fixed", inset: 0, zIndex: 998, background: "rgba(61,44,53,0.4)", display: "flex", alignItems: "center", justifyContent: "center", padding: 20, backdropFilter: "blur(6px)" }}>
        <div style={{ background: "#fff", borderRadius: 24, padding: 28, maxWidth: 360, width: "100%", boxShadow: "0 8px 40px rgba(200,140,160,0.3)", animation: "fadeUp 0.3s ease" }}>
          <div style={{ textAlign: "center", marginBottom: 16 }}>
            <span style={{ fontSize: 48 }}>{giftModal.emoji}</span>
            <h3 style={{ fontFamily: FNTD, fontSize: 20, color: S.tx, marginTop: 8 }}>Send {giftModal.label}</h3>
            <p style={{ fontSize: 12, color: S.txM, marginTop: 4 }}>{giftModal.prompt}</p>
          </div>
          <textarea value={giftNote} onChange={e => setGiftNote(e.target.value)} placeholder="e.g. Check the front door at 3pm tomorrow! ☕💕" rows={3} style={{ ...INP, resize: "none", fontFamily: FNT, marginBottom: 12 }} />
          <div style={{ display: "flex", gap: 8 }}>
            <button onClick={() => { setGiftModal(null); setGiftNote(""); }} style={{ ...BTN, flex: 1, background: S.blush, color: S.tx }}>Cancel</button>
            <button onClick={sendGift} style={{ ...BTN, flex: 1 }}>Send {giftModal.emoji}</button>
          </div>
          <p onClick={() => { setGiftNote(""); sendGift(); }} style={{ textAlign: "center", fontSize: 11, color: S.txM, marginTop: 10, cursor: "pointer", textDecoration: "underline" }}>Skip note & send now</p>
        </div>
      </div>}

      <div style={{ padding: "16px 20px 8px", display: "flex", alignItems: "center", justifyContent: "space-between" }}>
        <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
          <div onClick={() => { setPet(p => p + 1); setTimeout(() => setPet(0), 3000); }} style={{ cursor: "pointer", animation: pet > 0 ? "purr 0.4s ease infinite" : "none" }}>
            <Prudence mood={pet > 3 ? "excited" : pet > 0 ? "love" : "happy"} size={42} />
          </div>
          <div>
            <h1 style={{ fontFamily: FNTD, fontSize: 20, color: S.tx, fontWeight: 700 }}>Miss You, Pookie</h1>
            <p style={{ fontSize: 10, color: S.txM, letterSpacing: 0.5 }}>{p1} & {p2} 💕</p>
          </div>
        </div>
        <div style={{ fontSize: 10, color: S.txM, cursor: "pointer" }} onClick={() => setSetup(false)}>⚙️</div>
      </div>

      {pet > 0 && <div style={{ textAlign: "center", padding: "0 16px 8px", animation: "fadeUp 0.3s ease" }}><span style={{ fontSize: 11, color: S.rose, fontStyle: "italic" }}>{pet > 3 ? "Prudence is PURRING SO LOUD 😻" : pet > 1 ? "Prudence loves the pets! 🐾" : "*purrrr* 🐾"}</span></div>}

      <div style={{ padding: "0 16px 16px", animation: "fadeUp 0.5s ease" }}>
        {scr === "home" && <div>
          <div style={{ display: "flex", justifyContent: "center", marginBottom: 12, animation: "float 3s ease-in-out infinite" }}><PrudenceBubble text={pru.t} mood={pru.m} size={72} /></div>

          <div style={{ ...CRD, textAlign: "center", background: `linear-gradient(135deg,${S.rose}22,${S.lav}66)`, border: `1px solid ${S.rose}33` }}>
            <p style={{ fontSize: 11, color: S.txM, textTransform: "uppercase", letterSpacing: 2, marginBottom: 8 }}>Reunion Countdown</p>
            {rd && cd ? (cd.done ? <div><div style={{ fontSize: 26, fontFamily: FNTD, color: S.rose }}>They're home! 🎉</div><div style={{ marginTop: 8 }}><Prudence mood="excited" size={60} /></div></div> : <div><div style={{ display: "flex", justifyContent: "center", gap: 16 }}>{[["days", cd.d], ["hrs", cd.h], ["min", cd.m]].map(([l, v]) => <div key={l}><div style={{ fontSize: 34, fontWeight: 700, color: S.rose, fontFamily: FNTD }}>{v}</div><div style={{ fontSize: 10, color: S.txM, textTransform: "uppercase", letterSpacing: 1 }}>{l}</div></div>)}</div>{cd.d > 7 && <p style={{ fontSize: 11, color: S.txM, marginTop: 8, fontStyle: "italic" }}>Prudence is counting too 🐾</p>}</div>) : <div><p style={{ fontSize: 13, color: S.txL, marginBottom: 8 }}>When are you reuniting?</p><input type="date" value={rd} onChange={e => setRd(e.target.value)} style={{ ...INP, textAlign: "center", maxWidth: 200, margin: "0 auto" }} /></div>}
            {rd && <p onClick={() => setRd("")} style={{ fontSize: 11, color: S.txM, marginTop: 8, cursor: "pointer", textDecoration: "underline" }}>Change date</p>}
          </div>

          <div style={{ ...CRD, textAlign: "center", position: "relative", overflow: "hidden" }}>
            <div style={{ position: "absolute", top: -20, right: -15, opacity: 0.06 }}><Prudence mood="sleeping" size={85} /></div>
            <p style={{ fontSize: 11, color: S.txM, textTransform: "uppercase", letterSpacing: 2, marginBottom: 12 }}>Today's Shared Quote</p>
            <p style={{ fontFamily: FNTD, fontSize: 17, color: S.tx, lineHeight: 1.6, fontStyle: "italic", padding: "0 8px" }}>"{dq}"</p>
            <div style={{ marginTop: 14, display: "flex", justifyContent: "center", gap: 8 }}>
              {["❤️", "🥺", "💪", "🐾"].map(em => <button key={em} onClick={() => setQr(p => ({ ...p, [tk]: [...(p[tk] || []), em] }))} style={{ background: (qr[tk] || []).includes(em) ? S.blush : "transparent", border: `1px solid ${S.blush}`, borderRadius: 20, padding: "6px 12px", fontSize: 18, cursor: "pointer", transition: "all 0.2s" }}>{em}</button>)}
            </div>
            {(qr[tk] || []).length > 0 && <p style={{ fontSize: 11, color: S.txM, marginTop: 8 }}>Reacted: {(qr[tk] || []).join(" ")}</p>}
          </div>

          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
            {[{ e: "💌", l: "Send a Note", t: "notes" }, { e: "🎁", l: "Send a Gift", t: "gestures" }, { e: "📸", l: "Share a Moment", t: "feed" }, { e: "✨", l: "Plan a Date", t: "dates" }].map(a => <button key={a.t} onClick={() => setScr(a.t)} style={{ ...CRD, cursor: "pointer", border: "none", textAlign: "center", padding: 16, transition: "all 0.2s", display: "flex", flexDirection: "column", alignItems: "center", gap: 6 }}><span style={{ fontSize: 28 }}>{a.e}</span><span style={{ fontSize: 12, fontWeight: 600, color: S.tx }}>{a.l}</span></button>)}
          </div>

          {(gests.length > 0 || notes.length > 0) && <div style={{ ...CRD, marginTop: 10 }}>
            <p style={{ fontSize: 11, color: S.txM, textTransform: "uppercase", letterSpacing: 2, marginBottom: 10 }}>Recent Activity</p>
            {[...gests.slice(0, 2).map(g => ({ tp: "g", ...g })), ...notes.slice(0, 2).map(n => ({ tp: "n", ...n }))].sort((a, b) => new Date(b.time) - new Date(a.time)).slice(0, 3).map((it, i) => <div key={i} style={{ padding: "8px 0", borderBottom: i < 2 ? `1px solid ${S.blush}44` : "none", display: "flex", alignItems: "center", gap: 10 }}><span style={{ fontSize: 20 }}>{it.tp === "g" ? it.emoji : "💌"}</span><div><p style={{ fontSize: 13, color: S.tx }}>{it.tp === "g" ? `Sent ${it.label}${it.note ? " — " + it.note.slice(0, 30) + (it.note.length > 30 ? "..." : "") : ""}` : it.text?.slice(0, 40) + (it.text?.length > 40 ? "..." : "")}</p><p style={{ fontSize: 10, color: S.txM }}>{new Date(it.time).toLocaleDateString()}</p></div></div>)}
          </div>}
        </div>}

        {scr === "feed" && <div>
          <h2 style={SECT}>Our Moments 📸</h2>
          <p style={{ fontSize: 13, color: S.txL, marginBottom: 14 }}>Share photos and videos from your day — near or far.</p>
          <input type="file" accept="image/*,video/*" ref={fRef} style={{ display: "none" }} onChange={e => { const f = e.target.files?.[0]; if (!f) return; const r = new FileReader(); r.onload = ev => setPhotos(p => [{ data: ev.target.result, time: new Date().toISOString(), id: Date.now() }, ...p]); r.readAsDataURL(f); e.target.value = ""; }} />
          <button onClick={() => fRef.current?.click()} style={{ ...BTN, width: "100%", marginBottom: 16 }}>📷 Share a Moment</button>
          {photos.length === 0 ? <div style={{ ...CRD, textAlign: "center", padding: 32 }}><Prudence mood="sad" size={100} style={{ margin: "0 auto 8px" }} /><p style={{ color: S.txM, fontSize: 13, fontStyle: "italic" }}>No moments shared yet. Prudence is waiting!</p></div> :
            <div style={{ display: "grid", gap: 12 }}>{photos.map((p, i) => <div key={p.id} style={{ ...CRD, padding: 0, overflow: "hidden", animation: `slideIn 0.3s ease ${i * 0.1}s both` }}><img src={p.data} alt="" style={{ width: "100%", maxHeight: 300, objectFit: "cover", display: "block" }} /><div style={{ padding: 12, display: "flex", justifyContent: "space-between", alignItems: "center" }}><span style={{ fontSize: 11, color: S.txM }}>{new Date(p.time).toLocaleDateString()} · {new Date(p.time).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}</span><button onClick={() => setPhotos(pr => pr.filter(x => x.id !== p.id))} style={{ background: "none", border: "none", fontSize: 12, color: S.txM, cursor: "pointer" }}>🗑</button></div></div>)}</div>}
        </div>}

        {scr === "notes" && <div>
          <h2 style={SECT}>Love Notes 💌</h2>
          <p style={{ fontSize: 13, color: S.txL, marginBottom: 14 }}>Leave a little love for your person.</p>
          <div style={{ ...CRD, padding: 16 }}>
            <div style={{ display: "flex", gap: 8, marginBottom: 10 }}>
              <button onClick={() => setNs("1")} style={{ ...PILL, background: ns === "1" ? S.rose : "transparent", color: ns === "1" ? "#fff" : S.tx }}>{p1}</button>
              <button onClick={() => setNs("2")} style={{ ...PILL, background: ns === "2" ? S.rose : "transparent", color: ns === "2" ? "#fff" : S.tx }}>{p2}</button>
            </div>
            <textarea value={nn} onChange={e => setNn(e.target.value)} placeholder="Write something sweet..." rows={3} style={{ ...INP, resize: "none", width: "100%", fontFamily: FNT }} />
            <button onClick={() => { if (!nn.trim()) return; setNotes(p => [{ text: nn.trim(), sender: ns, time: new Date().toISOString(), id: Date.now() }, ...p]); setNn(""); }} style={{ ...BTN, width: "100%", marginTop: 8, opacity: nn.trim() ? 1 : 0.5 }}>Send Note 💌</button>
          </div>
          <div style={{ marginTop: 12, display: "grid", gap: 10 }}>
            {notes.length === 0 ? <div style={{ ...CRD, textAlign: "center", padding: 32 }}><Prudence mood="waving" size={100} style={{ margin: "0 auto 8px" }} /><p style={{ color: S.txM, fontSize: 13, fontStyle: "italic" }}>No notes yet! Prudence says go first.</p></div> :
              notes.map((n, i) => <div key={n.id} style={{ ...CRD, borderLeft: `3px solid ${n.sender === "1" ? S.rose : S.lavD}`, animation: `slideIn 0.3s ease ${i * 0.05}s both` }}><p style={{ fontSize: 14, color: S.tx, lineHeight: 1.6, marginBottom: 6 }}>{n.text}</p><div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}><span style={{ fontSize: 11, color: S.txM }}>From {n.sender === "1" ? p1 : p2} · {new Date(n.time).toLocaleDateString()}</span><button onClick={() => setNotes(p => p.filter(x => x.id !== n.id))} style={{ background: "none", border: "none", fontSize: 12, color: S.txM, cursor: "pointer" }}>🗑</button></div></div>)}
          </div>
        </div>}

        {scr === "gestures" && <div>
          <h2 style={SECT}>Sweet Gestures 🎁</h2>
          <p style={{ fontSize: 13, color: S.txL, marginBottom: 14 }}>Send a little something to brighten their day.</p>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
            {GESTURES.map(g => <button key={g.id} onClick={() => setGiftModal(g)} style={{ ...CRD, cursor: "pointer", border: "none", textAlign: "center", padding: 20, transition: "all 0.2s", display: "flex", flexDirection: "column", alignItems: "center", gap: 6 }}><span style={{ fontSize: 36 }}>{g.emoji}</span><span style={{ fontSize: 13, fontWeight: 600, color: g.color }}>Send {g.label}</span></button>)}
          </div>
          {gests.length > 0 ? <div style={{ marginTop: 16 }}>
            <p style={{ fontSize: 11, color: S.txM, textTransform: "uppercase", letterSpacing: 2, marginBottom: 10 }}>Gesture History</p>
            {gests.slice(0, 10).map((g, i) => <div key={g.id} style={{ display: "flex", alignItems: "flex-start", gap: 10, padding: "10px 0", borderBottom: `1px solid ${S.blush}33`, animation: `slideIn 0.3s ease ${i * 0.05}s both` }}>
              <span style={{ fontSize: 22, marginTop: 2 }}>{g.emoji}</span>
              <div style={{ flex: 1 }}>
                <p style={{ fontSize: 13, color: S.tx, fontWeight: 600 }}>Sent {g.label}</p>
                {g.note && <div style={{ background: S.blush, borderRadius: 10, padding: "6px 10px", marginTop: 4, fontSize: 12, color: S.tx, lineHeight: 1.5 }}>📍 {g.note}</div>}
                <p style={{ fontSize: 10, color: S.txM, marginTop: 3 }}>{new Date(g.time).toLocaleDateString()} · {new Date(g.time).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}</p>
              </div>
            </div>)}
          </div> :
            <div style={{ textAlign: "center", marginTop: 20 }}><Prudence mood="waving" size={80} style={{ margin: "0 auto" }} /><p style={{ color: S.txM, fontSize: 12, fontStyle: "italic", marginTop: 4 }}>Prudence approves of gift-giving!</p></div>}
        </div>}

        {scr === "dates" && <div>
          <h2 style={SECT}>Date Night Ideas ✨</h2>
          <p style={{ fontSize: 13, color: S.txL, marginBottom: 14 }}>Save ideas for when you're reunited. Tap the heart to save!</p>
          {sdates.length > 0 && <div style={{ ...CRD, marginBottom: 14, background: `linear-gradient(135deg,${S.rose}11,${S.lav}44)` }}>
            <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 8 }}><Prudence mood="excited" size={34} /><p style={{ fontSize: 11, color: S.txM, textTransform: "uppercase", letterSpacing: 2 }}>Saved ({sdates.length})</p></div>
            <div style={{ display: "flex", flexWrap: "wrap", gap: 6 }}>{sdates.map(idx => <span key={idx} style={{ background: S.blush, borderRadius: 12, padding: "4px 10px", fontSize: 12, color: S.tx }}>{DATE_IDEAS[idx]?.emoji} {DATE_IDEAS[idx]?.title}</span>)}</div>
          </div>}
          <div style={{ display: "grid", gap: 10 }}>{DATE_IDEAS.map((d, i) => <div key={i} onClick={() => setSdates(p => p.includes(i) ? p.filter(x => x !== i) : [...p, i])} style={{ ...CRD, cursor: "pointer", display: "flex", alignItems: "center", gap: 14, padding: 16, transition: "all 0.2s", border: sdates.includes(i) ? `2px solid ${S.rose}44` : `1px solid transparent`, animation: `slideIn 0.3s ease ${i * 0.04}s both` }}><span style={{ fontSize: 32 }}>{d.emoji}</span><div style={{ flex: 1 }}><p style={{ fontSize: 14, fontWeight: 600, color: S.tx }}>{d.title}</p><p style={{ fontSize: 12, color: S.txL, marginTop: 2 }}>{d.desc}</p></div><span style={{ fontSize: 20, opacity: sdates.includes(i) ? 1 : 0.25, transition: "all 0.2s" }}>{sdates.includes(i) ? "❤️" : "🤍"}</span></div>)}</div>
        </div>}
      </div>

      <div style={{ position: "fixed", bottom: 0, left: 0, right: 0, background: "rgba(255,252,248,0.95)", backdropFilter: "blur(20px)", borderTop: `1px solid ${S.blush}55`, display: "flex", justifyContent: "space-around", padding: "6px 0 env(safe-area-inset-bottom, 12px)", zIndex: 100 }}>
        {tabs.map(t => <button key={t.id} onClick={() => setScr(t.id)} style={{ background: "none", border: "none", cursor: "pointer", display: "flex", flexDirection: "column", alignItems: "center", gap: 2, opacity: scr === t.id ? 1 : 0.5, transition: "all 0.2s", transform: scr === t.id ? "scale(1.1)" : "scale(1)" }}><span style={{ fontSize: 20 }}>{t.e}</span><span style={{ fontSize: 9, fontWeight: 600, color: scr === t.id ? S.rose : S.txM, letterSpacing: 0.5 }}>{t.l}</span></button>)}
      </div>
    </div>
  );
}
